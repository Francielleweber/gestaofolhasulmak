# Banco de dados MySQL (Railway preenche automaticamente)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=sulmak

# Porta do servidor (Railway define automaticamente)
PORT=3000

# Chave secreta para a API (crie uma string aleatória longa)
API_SECRET=troque_por_uma_chave_secreta_longa_aqui
